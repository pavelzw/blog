---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  alt: string;
  lightSrc: ImageMetadata;
  darkSrc: ImageMetadata;
  class?: string;
}

const { alt, lightSrc, darkSrc, class: className } = Astro.props;
---

<!-- Light mode image -->
<Image
  src={lightSrc}
  alt={alt}
  class:list={['dark:hidden', className]}
  loading="lazy"
/>
<!-- Dark mode image -->
<Image
  src={darkSrc}
  alt={alt}
  class:list={['hidden dark:block', className]}
  loading="lazy"
/>
