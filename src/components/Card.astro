---
interface Props {
  title: string;
  description: string;
  imgSrc?: string;
  href?: string;
}

const { title, description, imgSrc, href } = Astro.props;
---

<div class="max-w-[544px] p-4 md:w-1/2">
  <div
    class:list={[
      'overflow-hidden rounded-md border-2 border-gray-200/60 dark:border-gray-700',
      imgSrc && 'h-full',
    ]}
  >
    {imgSrc && (
      <div class="aspect-video bg-gray-100 dark:bg-gray-800">
        {href ? (
          <a href={href} aria-label={`Link to ${title}`}>
            <img
              alt={title}
              src={imgSrc}
              class="h-full w-full object-cover object-center"
              width={544}
              height={306}
              loading="lazy"
            />
          </a>
        ) : (
          <img
            alt={title}
            src={imgSrc}
            class="h-full w-full object-cover object-center"
            width={544}
            height={306}
            loading="lazy"
          />
        )}
      </div>
    )}
    <div class="p-6">
      <h2 class="mb-3 text-2xl font-bold leading-8 tracking-tight">
        {href ? (
          <a href={href} aria-label={`Link to ${title}`} class="hover:text-primary-500 dark:hover:text-primary-400">
            {title}
          </a>
        ) : (
          title
        )}
      </h2>
      <p class="prose mb-3 max-w-none text-gray-500 dark:text-gray-400">{description}</p>
      {href && (
        <a
          href={href}
          class="text-base font-medium leading-6 text-primary-500 hover:text-primary-600 dark:hover:text-primary-400"
          aria-label={`Link to ${title}`}
        >
          Learn more &rarr;
        </a>
      )}
    </div>
  </div>
</div>
