---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Badge from './Badge.astro';

interface Props {
  title: string;
  img?: ImageMetadata;
  href?: string;
  badge?: { github: string; label?: string } | { youtube: string; label?: string };
  imgBgColor?: string;
  imgContain?: boolean;
  imgPosition?: 'top' | 'center' | 'bottom';
}

const { title, img, href, badge, imgBgColor, imgContain, imgPosition } = Astro.props;
---

<div class="w-full p-4 md:w-1/2 md:max-w-[544px]">
  <div
    class:list={[
      'overflow-hidden rounded-md border-2 border-gray-200/60 dark:border-gray-700',
      img && 'h-full',
    ]}
  >
    {img && (
      <div
        class="aspect-video overflow-hidden"
        style={imgBgColor ? `background-color: ${imgBgColor}` : undefined}
      >
        {href ? (
          <a href={href} aria-label={`Link to ${title}`}>
            <Image
              alt={title}
              src={img}
              width={544}
              height={306}
              class:list={['h-full w-full', imgContain ? 'object-contain' : 'object-cover']}
              style={imgPosition ? `object-position: ${imgPosition}` : undefined}
              loading="lazy"
            />
          </a>
        ) : (
          <Image
            alt={title}
            src={img}
            width={544}
            height={306}
            class:list={['h-full w-full', imgContain ? 'object-contain' : 'object-cover']}
            style={imgPosition ? `object-position: ${imgPosition}` : undefined}
            loading="lazy"
          />
        )}
      </div>
    )}
    <div class="p-6">
      <div class="mb-3 flex items-center justify-between gap-2">
        <h2 class="text-2xl font-bold leading-8 tracking-tight">
          {href ? (
            <a href={href} aria-label={`Link to ${title}`} class="hover:text-primary-500 dark:hover:text-primary-400">
              {title}
            </a>
          ) : (
            title
          )}
        </h2>
        {badge && <Badge badge={badge} title={title} />}
      </div>
      <p class="prose mb-3 max-w-none text-gray-500 dark:text-gray-400">
        <slot />
      </p>
    </div>
  </div>
</div>
