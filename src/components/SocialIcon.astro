const sizeClass = `h-${size} w-${size}`;
const isStroke = kind === 'mail';
---

{href && (
  <a
    class="text-sm text-gray-500 transition hover:text-gray-600 dark:hover:text-gray-400"
    target={kind === 'mail' ? '_self' : '_blank'}
    rel="noopener noreferrer"
    href={href}
  >
    <span class="sr-only">{kind}</span>
    <svg
      viewBox={kind === 'mail' ? '0 0 24 24' : '0 0 24 24'}
      class={sizeClass}
      fill={isStroke ? 'none' : 'currentColor'}
      stroke={isStroke ? 'currentColor' : 'none'}
      set:html={icons[kind]}
    />
  </a>
)}
