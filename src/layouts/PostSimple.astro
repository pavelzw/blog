---
import BaseLayout from './BaseLayout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Badge from '../components/Badge.astro';
import Giscus from '../components/Giscus.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  prevPost?: CollectionEntry<'blog'>;
  nextPost?: CollectionEntry<'blog'>;
}

const { post, prevPost, nextPost } = Astro.props;
const { title, date, summary, badges } = post.data;
---

<BaseLayout title={title} description={summary} article={true}>
  <article>
    <div>
      <header>
        <div class="space-y-1 border-b border-gray-200 pb-10 text-center dark:border-gray-700">
          <dl>
            <div>
              <dt class="sr-only">Published on</dt>
              <dd class="flex items-center justify-center gap-2 text-base font-medium leading-6 text-gray-500 dark:text-gray-400">
                <FormattedDate date={date} />
                {badges.map((badge) => <Badge badge={badge} title={title} />)}
              </dd>
            </div>
          </dl>
          <div>
            <h1 class="text-3xl font-extrabold leading-9 tracking-tight text-gray-900 dark:text-gray-100 sm:text-4xl sm:leading-10 md:text-5xl md:leading-14">
              {title}
            </h1>
          </div>
        </div>
      </header>
      <div class="prose max-w-none pb-8 pt-10 dark:prose-invert">
        <slot />
      </div>
      <Giscus />
      <footer>
        <div class="flex flex-col text-sm font-medium sm:flex-row sm:justify-between sm:text-base">
          {prevPost && (
            <div class="pt-4 xl:pt-8">
              <a
                href={`/blog/${prevPost.slug}`}
                class="text-primary-500 hover:text-primary-600 dark:hover:text-primary-400"
                aria-label={`Previous post: ${prevPost.data.title}`}
              >
                &larr; {prevPost.data.title}
              </a>
            </div>
          )}
          {nextPost && (
            <div class="pt-4 xl:pt-8">
              <a
                href={`/blog/${nextPost.slug}`}
                class="text-primary-500 hover:text-primary-600 dark:hover:text-primary-400"
                aria-label={`Next post: ${nextPost.data.title}`}
              >
                {nextPost.data.title} &rarr;
              </a>
            </div>
          )}
        </div>
      </footer>
    </div>
  </article>
</BaseLayout>
