---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteMetadata } from '../data/siteMetadata';
import SocialIcon from '../components/SocialIcon.astro';

const { author } = siteMetadata;
---

<BaseLayout title="About">
  <div class="divide-y divide-gray-200 dark:divide-gray-700">
    <div class="space-y-2 pb-8 pt-6 md:space-y-5">
      <h1 class="text-3xl font-extrabold leading-9 tracking-tight text-gray-900 dark:text-gray-100 sm:text-4xl sm:leading-10 md:text-6xl md:leading-14">
        About
      </h1>
    </div>
    <div class="items-start space-y-2 xl:grid xl:grid-cols-3 xl:gap-x-8 xl:space-y-0">
      <div class="flex flex-col items-center space-x-2 pt-8">
        <img
          src={author.avatar}
          alt={author.name}
          class="h-48 w-48 rounded-full"
        />
        <h3 class="pb-2 pt-4 text-2xl font-bold leading-8 tracking-tight">
          {author.name}
        </h3>
        <div class="text-gray-500 dark:text-gray-400">{author.occupation}</div>
        <div class="text-gray-500 dark:text-gray-400">{author.company}</div>
        <div class="flex space-x-3 pt-6">
          <SocialIcon kind="mail" href={`mailto:${author.email}`} />
          <SocialIcon kind="github" href={author.github} />
          <SocialIcon kind="linkedin" href={author.linkedin} />
          <SocialIcon kind="youtube" href={author.youtube} />
          <SocialIcon kind="rss" href="/feed.xml" />
        </div>
      </div>
      <div class="prose max-w-none pb-8 pt-8 dark:prose-invert xl:col-span-2">
        <p>
          I am a software engineer at <a href="https://quantco.com">QuantCo</a>, where I work on building
          data pipelines and machine learning models for insurance companies.
          I enjoy working on developer tooling and have built various things to make my people's lives easier.
        </p>
        <p>
          Click <a href="/cv">here</a> to see my CV.
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
