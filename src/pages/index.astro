---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import Badge from '../components/Badge.astro';
import { siteMetadata } from '../data/siteMetadata';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout>
  <div class="divide-y divide-gray-200 dark:divide-gray-700">
    <div class="space-y-2 pb-8 pt-6 md:space-y-5">
      <h1 class="text-3xl font-extrabold leading-9 tracking-tight text-gray-900 dark:text-gray-100 sm:text-4xl sm:leading-10 md:text-6xl md:leading-14">
        Blog
      </h1>
      <p class="text-lg leading-7 text-gray-500 dark:text-gray-400">
        {siteMetadata.description}
      </p>
    </div>
    <ul class="divide-y divide-gray-200 dark:divide-gray-700">
      {posts.map((post) => {
        const { date, title, summary, badges } = post.data;
        return (
          <li class="py-12">
            <article>
              <div class="space-y-2 xl:grid xl:grid-cols-4 xl:items-baseline xl:space-y-0">
                <dl>
                  <dt class="sr-only">Published on</dt>
                  <dd class="flex flex-wrap items-center gap-2 text-base font-medium leading-6 text-gray-500 dark:text-gray-400">
                    <FormattedDate date={date} />
                    {badges.map((badge) => <Badge badge={badge} title={title} />)}
                  </dd>
                </dl>
                <div class="space-y-5 xl:col-span-3">
                  <div class="space-y-6">
                    <div>
                      <h2 class="text-2xl font-bold leading-8 tracking-tight">
                        <a
                          href={`/blog/${post.slug}`}
                          class="text-gray-900 dark:text-gray-100 hover:text-primary-500 dark:hover:text-primary-400"
                        >
                          {title}
                        </a>
                      </h2>
                    </div>
                    <div class="prose max-w-none text-gray-500 dark:text-gray-400">
                      {summary}
                    </div>
                  </div>
                  <div class="text-base font-medium leading-6">
                    <a
                      href={`/blog/${post.slug}`}
                      class="text-primary-500 hover:text-primary-600 dark:hover:text-primary-400"
                      aria-label={`Read more: "${title}"`}
                    >
                      Read more &rarr;
                    </a>
                  </div>
                </div>
              </div>
            </article>
          </li>
        );
      })}
    </ul>
  </div>
</BaseLayout>
