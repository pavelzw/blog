---
import { getCollection, type CollectionEntry } from 'astro:content';
import PostLayout from '../../layouts/PostLayout.astro';
import PostSimple from '../../layouts/PostSimple.astro';
import PostBanner from '../../layouts/PostBanner.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  
  return sortedPosts.map((post, index) => ({
    params: { slug: post.slug },
    props: {
      post,
      prevPost: sortedPosts[index + 1] || null,
      nextPost: sortedPosts[index - 1] || null,
    },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
  prevPost: CollectionEntry<'blog'> | null;
  nextPost: CollectionEntry<'blog'> | null;
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await post.render();
const layout = post.data.layoutType || 'PostLayout';

const layouts = {
  PostLayout,
  PostSimple,
  PostBanner,
};

const LayoutComponent = layouts[layout as keyof typeof layouts] || PostLayout;
---

<LayoutComponent post={post} prevPost={prevPost} nextPost={nextPost}>
  <Content />
</LayoutComponent>
